{
  "name": "docs",
  "version": "0.1.0",
  "private": true,
  "description": "Capacitr whitepaper, brief, and documentation site",
  "type": "module",
  "scripts": {
    "dev": "vitepress dev content",
    "build": "vitepress build content",
    "preview": "vitepress preview content",
    "build:whitepaper": "node scripts/build-whitepaper.js",
    "build:brief": "node scripts/build-brief.js",
    "build:docs": "npm run build:whitepaper && npm run build:brief",
    "build:all": "npm run build:docs && npm run build",
    "snapshot": "node scripts/snapshot-version.js"
  },
  "dependencies": {
    "docx": "^9.0.0",
    "gray-matter": "^4.0.3",
    "markdown-it": "^14.0.0",
    "vue": "^3.4.15"
  },
  "devDependencies": {
    "@types/node": "^22.10.7",
    "typescript": "^5.3.3",
    "vitepress": "^1.6.3"
  }
}
