{
  "name": "capacitr",
  "private": true,
  "packageManager": "pnpm@9.0.4",
  "scripts": {
    "lint": "turbo lint",
    "env:build": "ce build --profile",
    "dev:docs": "ce run --profile -- turbo dev --filter=docs",
    "build:docs": "ce run --profile -- turbo build --filter=docs",
    "start:docs": "ce run --profile -- turbo start --filter=docs",
    "dev:sim": "ce run --profile -- turbo dev --filter=sim",
    "build:sim": "ce run --profile -- turbo build --filter=sim",
    "start:sim": "ce run --profile -- turbo start --filter=sim",
    "dev:launchpad": "ce run --profile -- turbo dev --filter=launchpad",
    "build:launchpad": "ce run --profile -- turbo build --filter=launchpad",
    "start:launchpad": "ce run --profile -- turbo start --filter=launchpad",
    "dev:lpv2": "ce run --profile -- turbo dev --filter=lpv2",
    "build:lpv2": "ce run --profile -- turbo build --filter=lpv2",
    "start:lpv2": "ce run --profile -- turbo start --filter=lpv2",
    "build:contracts": "ce run --profile -- turbo build --filter=contracts",
    "db:push": "ce run --profile -- pnpm --filter=@capacitr/database db:push",
    "db:studio": "ce run --profile -- pnpm --filter=@capacitr/database db:studio",
    "dev": "ce run --profile default -- turbo dev",
    "build": "ce run --profile default -- turbo build",
    "start": "ce run --profile default -- turbo start"
  },
  "devDependencies": {
    "composable.env": "0.8.1",
    "turbo": "^2"
  }
}
