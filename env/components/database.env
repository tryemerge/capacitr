NAMESPACE=DATABASE

[default]
HOST=localhost
PORT=5432
NAME=myapp_dev
USER=postgres
PASSWORD=postgres

[staging]
HOST=${DATABASE_STAGING_HOST}
NAME=myapp_staging
USER=${DATABASE_STAGING_USER}
PASSWORD=${DATABASE_STAGING_PASSWORD}

[production]
HOST=${DATABASE_PROD_HOST}
PORT=5432
NAME=myapp
USER=${DATABASE_PROD_USER}
PASSWORD=${DATABASE_PROD_PASSWORD}
