# ──────────────────────────────────────────────────
# Capacitr — Secrets / Local Overrides
# ──────────────────────────────────────────────────
# Copy this file to env/.env.local and fill in values.
# The composable env system (ce.json) references these
# via ${secrets.KEY_NAME} syntax in component .env files.
#
# .env.local is gitignored — never commit real secrets.
# ──────────────────────────────────────────────────

# ── Database (GCP Cloud SQL) ──
GCP_DB_PASSWORD=

# ── Privy Auth ──
PRIVY_APP_SECRET=
PRIVY_CLIENT_ID=

# ── Google OAuth (Better Auth / legacy) ──
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Session ──
SESSION_SECRET=
