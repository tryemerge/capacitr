# composable.env vault recipients
# Each line: public key [optional comment]
#
# Add team members with: ce vault add --github <username>
# Add keys directly with: ce vault add --key "age1..." --comment "name"
#
# Supported key types:
#   age1...           (native age public key)
#   ssh-ed25519 AAAA... (SSH ed25519 public key)
#   ssh-rsa AAAA...     (SSH RSA public key)
#
