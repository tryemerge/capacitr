{
  "name": "sim",
  "location": "apps/sim",
  "vars": {
    "DATABASE_URL": "postgresql://${database.GCP_USER}:${database.GCP_PASSWORD}@${database.GCP_HOST}:${database.GCP_POOL_PORT}/${database.GCP_NAME}?${database.GCP_POOL_CONNECTION_URL_PARAMS}",
    "DIRECT_URL": "postgresql://${database.GCP_USER}:${database.GCP_PASSWORD}@${database.GCP_HOST}:${database.GCP_PORT}/${database.GCP_NAME}?${database.GCP_CONNECTION_URL_PARAMS}",
    "SESSION_SECRET": "${sim.SESSION_SECRET}",
    "GOOGLE_CLIENT_ID": "${google.AUTH_CLIENT_ID}",
    "GOOGLE_CLIENT_SECRET": "${google.AUTH_CLIENT_SECRET}",
    "ALLOWED_EMAILS": "${better-auth.ALLOWED_EMAILS}",
    "BETTER_AUTH_URL": "${sim.BETTER_AUTH_URL}",
    "PORT": "${SIM_PORT}",
    "LOG_LEVEL": "${LOG_LEVEL}"
  },
  "defaults": {
    "BETTER_AUTH_URL": "http://localhost:3000",
    "PORT": "3000",
    "LOG_LEVEL": "info"
  },
  "dev": {
    "command": "pnpm dev",
    "label": "Sim"
  }
}
