{
  "name": "lpv2",
  "location": "apps/lpv2",
  "vars": {
    "DATABASE_URL": "${secrets.LPV2_DATABASE_URL}",
    "DIRECT_URL": "${secrets.LPV2_DIRECT_URL}",
    "NEXT_PUBLIC_PRIVY_APP_ID": "${privy.APP_ID}",
    "PRIVY_APP_SECRET": "${privy.APP_SECRET}",
    "BASE_URL": "${launchpad.V2_BASE_URL}",
    "GOOGLE_API_KEY": "${secrets.GOOGLE_API_KEY}",
    "BLOB_READ_WRITE_TOKEN": "${secrets.BLOB_READ_WRITE_TOKEN}",
    "PORT": "${LPV2_PORT}",
    "LOG_LEVEL": "${LOG_LEVEL}"
  },
  "defaults": {
    "PORT": "3002",
    "LOG_LEVEL": "info"
  },
  "dev": {
    "command": "pnpm dev",
    "label": "Launchpad v2"
  }
}
